#!/usr/bin/env bash
# Block commits that contain known secret patterns.
#
# Setup (per clone):
#     git config --local core.hooksPath .githooks
#     chmod +x .githooks/pre-commit
#
# Bypass is intentionally annoying — only use --no-verify when you're
# 100% sure a match is a false positive.

set -u

# Get the staged diff (added lines only)
diff_added() {
    git diff --cached --no-color --diff-filter=AM -U0 -- \
        ':(exclude)*.lock' ':(exclude)*-lock.json' ':(exclude).git/**' \
        ':(exclude).venv/**' ':(exclude)node_modules/**' \
        | grep -E '^\+' | grep -vE '^\+\+\+' || true
}

CONTENT="$(diff_added)"
if [[ -z "$CONTENT" ]]; then
    exit 0
fi

violations=0

block() {
    local label="$1"
    local pattern="$2"
    local matches
    matches=$(printf '%s\n' "$CONTENT" | grep -E -- "$pattern" || true)
    if [[ -n "$matches" ]]; then
        echo "❌ pre-commit: blocked — $label"
        echo "   Pattern: $pattern"
        echo "   Matched lines:"
        printf '%s\n' "$matches" | head -5 | sed 's/^/     /'
        echo
        violations=$((violations + 1))
    fi
}

# === HARD BLOCKS — these are real credentials, no ambiguity ===

# Telegram bot token: 8-12 digit ID, colon, 35 base64-ish chars.
block "Telegram bot token" \
    '\b[0-9]{8,12}:[A-Za-z0-9_-]{30,}\b'

# Ethereum/HyperLiquid private key (64 hex chars after 0x).
# Use case-insensitive whole-word match.
block "Ethereum/HyperLiquid private key (0x + 64 hex)" \
    '\b0x[a-fA-F0-9]{64}\b'

# Cloudflare API token: 40 chars of base64 alphabet, often near "cloudflare"
# or assigned to CF_TOKEN/CLOUDFLARE_API_TOKEN. Match conservatively to
# avoid false positives — require neighboring context.
block "Cloudflare API token (heuristic)" \
    '(CF|CLOUDFLARE)_(API_)?TOKEN[ =:]+["'"'"']?[A-Za-z0-9_-]{30,}'

# AWS access key
block "AWS access key" 'AKIA[0-9A-Z]{16}\b'

# Generic high-entropy SECRET_KEY/API_KEY assignment.
# Matches: KEY = "value", KEY: "value" (YAML), KEY=value (dotenv).
# `[:=]` covers both Python-style and YAML/compose syntax; quotes
# optional so unquoted dotenv lines also fire. Kept in sync with
# .gitleaks.toml — update both together.
block "Hardcoded SECRET_KEY/API_KEY/PASSWORD literal" \
    '(SECRET_KEY|API_KEY|PASSWORD|PRIVATE_KEY)[ ]*[:=][ ]*["'"'"']?[A-Za-z0-9_+/=-]{16,}["'"'"']?'

# Personal/paid data sources — block by file path. Catches accidental
# additions of files under bot/data/private/ or docs/ files matching
# known paid-data patterns even if .gitignore was edited away.
staged_files=$(git diff --cached --name-only --diff-filter=AM 2>/dev/null || true)
forbidden_files=$(printf '%s\n' "$staged_files" | grep -E \
    '^(bot/data/private/|docs/.*cookies|docs/.*roots|docs/.*bitcoinstrategyplatform|docs/.*\.har|docs/.*\.csv|docs/bitcoin_hodl_strategy)' || true)
if [[ -n "$forbidden_files" ]]; then
    echo "❌ pre-commit: blocked — paid/personal data file(s) staged"
    echo "   These paths are gitignored AND blocked by the hook:"
    printf '%s\n' "$forbidden_files" | sed 's/^/     /'
    echo "   Move the file out of these paths or add a more specific exception."
    echo
    violations=$((violations + 1))
fi

# === SOFT BLOCKS — likely sensitive but high false positives. Warn-only ===

soft_warn() {
    local label="$1"
    local pattern="$2"
    local matches
    matches=$(printf '%s\n' "$CONTENT" | grep -E -- "$pattern" || true)
    if [[ -n "$matches" ]]; then
        echo "⚠️  pre-commit: heads-up — $label"
        printf '%s\n' "$matches" | head -3 | sed 's/^/     /'
        echo "   (commit allowed, but verify it's intentional)"
        echo
    fi
}

# PCRE variants of block / soft_warn for patterns that need word
# boundaries (\b), lookaround, or other Perl-only features. POSIX ERE
# (grep -E) doesn't define \b — GNU grep extends it but inconsistently
# (works around word chars, fails before /). Patterns added 2026-05-11
# after the security audit use these so they actually fire.
block_pcre() {
    local label="$1"
    local pattern="$2"
    local matches
    matches=$(printf '%s\n' "$CONTENT" | grep -P -- "$pattern" || true)
    if [[ -n "$matches" ]]; then
        echo "❌ pre-commit: blocked — $label"
        echo "   Pattern: $pattern"
        echo "   Matched lines:"
        printf '%s\n' "$matches" | head -5 | sed 's/^/     /'
        echo
        violations=$((violations + 1))
    fi
}

soft_warn_pcre() {
    local label="$1"
    local pattern="$2"
    local matches
    matches=$(printf '%s\n' "$CONTENT" | grep -P -- "$pattern" || true)
    if [[ -n "$matches" ]]; then
        echo "⚠️  pre-commit: heads-up — $label"
        printf '%s\n' "$matches" | head -3 | sed 's/^/     /'
        echo "   (commit allowed, but verify it's intentional)"
        echo
    fi
}

# Private LAN IPs (192.168.x, 10.x). Often deployment-specific.
soft_warn "private LAN IP" \
    '\b(192\.168|10\.[0-9]+|172\.(1[6-9]|2[0-9]|3[01]))\.[0-9]+\.[0-9]+\b'

# Personal email
soft_warn "personal email address" \
    '[a-zA-Z0-9._%+-]+@(gmail|outlook|hotmail|protonmail|yahoo|icloud)\.com'

# Operator-owned domains. The repo is public — every appearance of
# these in committed code/docs leaks operator identity. Added after
# the 2026-05-11 security audit found 8+ leaks across config + docs.
# Soft-warn (not block) because CLAUDE.md § 0 documents the policy
# itself — when this fires on a CLAUDE.md edit, verify it's docs,
# not a real value.
soft_warn_pcre "operator-owned personal/company domain" \
    '\b(xuper\.fun|molnkontakt\.se)\b'

# Operator-specific service subdomains (auth/phase/secrets/console
# prefixes commonly map to the operator's IdP, secret-manager, or
# admin URL). Use placeholders ($PHASE_URL, auth.example.com, etc).
soft_warn_pcre "operator-specific service subdomain (auth/phase/secrets/console.*)" \
    '\b(auth|phase|secrets|console|admin|api)\.[a-z0-9-]+\.(fun|com|net|org|io|dev|se|app)\b'

# Absolute /home/<user>/ paths reveal the operator's local OS user
# in any committed shell snapshot, generated doc, or accidentally
# pasted log. CLAUDE.md is path-allowlisted in .gitleaks.toml since
# it documents the rule itself; this hook doesn't filter by file
# but a CLAUDE.md edit that mentions /home/ as documentation will
# block here — add the path to the allowlist below if intentional.
# (PCRE because POSIX ERE \b doesn't match before non-word /.)
block_pcre "absolute /home/<user>/ path (use ~/path or relative)" \
    '(?<![a-zA-Z0-9])/home/[a-z][a-z0-9_-]{1,30}/'

if [[ $violations -gt 0 ]]; then
    echo "Blocked $violations secret pattern(s) — refusing commit."
    echo
    echo "If this is genuinely a false positive:"
    echo "  1. Verify the value is NOT a real credential."
    echo "  2. Rephrase to avoid the pattern (e.g. 'TOKEN_LIKE_THIS' instead of a literal-shaped value)."
    echo "  3. Last resort: git commit --no-verify  (use with extreme caution)."
    exit 1
fi

exit 0
