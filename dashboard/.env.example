# ─── Database ─────────────────────────────────────────────────────────────────
# Same Postgres instance as the bot. Adjust host if not using Docker Compose.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hypertrade

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Bot API endpoints ────────────────────────────────────────────────────────
# These are the internal URLs to each bot's HTTP API (used for /status, /pause, etc.)
# In Docker Compose these are container names; for local dev use localhost:port.
BOT_API_URL_PAPER=http://localhost:8000
BOT_API_URL_TESTNET=http://localhost:8001
BOT_API_URL_MAINNET=http://localhost:8002

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must match API_KEY in the bot's .env (leave empty to disable auth)
API_KEY=

# ─── Dashboard ────────────────────────────────────────────────────────────────
# Used for CORS — set to the URL where this dashboard is accessible
DASHBOARD_URL=http://localhost:3000

# ─── OIDC invite gate (security audit M-3) ────────────────────────────────────
# When set, OIDC sign-in for a brand-new user only autocreates a tenant row
# if the IdP-issued `groups` claim contains this exact value. Empty/unset =
# no enforcement (back-compat: any successful OIDC auth autocreates a tenant,
# the pre-M-3 default). For Authentik-backed deployments the recommended
# value is `hypertrade-users` per docs/INVITE_ONBOARDING.md.
#
# Group enforcement only fires on autocreate. Existing tenants (already in
# the table) are NOT re-checked on login — revocation flows through M-2's
# `is_active` flag, not OIDC group membership (which can flap and shouldn't
# break logged-in users mid-session).
OIDC_REQUIRED_GROUP=
