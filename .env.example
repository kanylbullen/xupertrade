# ─── Exchange mode ────────────────────────────────────────────────────────────
EXCHANGE_MODE=paper              # paper | testnet | mainnet

# ─── HyperLiquid — testnet ────────────────────────────────────────────────────
# Required when EXCHANGE_MODE=testnet
# Generate at: https://app.hyperliquid-testnet.xyz → Settings → API
HYPERLIQUID_PRIVATE_KEY=         # private key of the signing wallet (0x...)
HYPERLIQUID_ACCOUNT_ADDRESS=     # trading account address — leave empty if signing wallet IS the account

# ─── HyperLiquid — mainnet ────────────────────────────────────────────────────
# Required when EXCHANGE_MODE=mainnet (bot-mainnet container, --profile mainnet)
HYPERLIQUID_MAINNET_PRIVATE_KEY=
HYPERLIQUID_MAINNET_ACCOUNT_ADDRESS=

# ─── Vault tracking (read-only) ───────────────────────────────────────────────
# Mainnet wallet address used to query the user's vault deposits via HL's
# `userVaultEquities` endpoint. PUBLIC ADDRESS only — no private key — since
# vault equities are public on-chain. Leave empty to disable the
# "My vault positions" panel on the /vaults dashboard page.
VAULT_TRACKING_ADDRESS=

# ─── Portfolio page (read-only) ───────────────────────────────────────────────
# Comma-separated list of providers to render on /portfolio. Each shows
# up as its own card. Special value "*" enables every provider whose
# connection vars are set below.
#
#   PORTFOLIO_PROVIDERS=                       → page disabled
#   PORTFOLIO_PROVIDERS=rotki                  → only Rotki
#   PORTFOLIO_PROVIDERS=rotki,ghostfolio       → both side-by-side
#   PORTFOLIO_PROVIDERS=*                      → all configured
PORTFOLIO_PROVIDERS=

# Rotki — open source, self-hosted (https://rotki.com). Crypto + DeFi
# focused. Run a rotki backend (e.g. via the official Docker image) and
# point us at it. Premium subscription not needed for local instance.
ROTKI_URL=                # e.g. http://rotki:5042 (when in same Compose net)
ROTKI_USERNAME=
ROTKI_PASSWORD=

# Ghostfolio — open source, self-hosted (https://ghostfol.io). Broader
# asset universe (stocks/ETFs/funds/crypto). Bearer-token auth — generate
# from Ghostfolio settings → Membership → "Security token".
GHOSTFOLIO_URL=           # e.g. http://ghostfolio:3333
GHOSTFOLIO_TOKEN=

# CoinStats — third-party SaaS, requires Degen plan, 8 credits/request
# (cached 5 min). Share token from CoinStats app → portfolio → share.
COINSTATS_API_KEY=
COINSTATS_SHARE_TOKEN=
# Optional: set only if portfolio is passcode-protected on CoinStats.
COINSTATS_PASSCODE=

# ─── Paper trading ────────────────────────────────────────────────────────────
PAPER_INITIAL_BALANCE=10000.0

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker Compose default — matches postgres service in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hypertrade

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Engine ───────────────────────────────────────────────────────────────────
DEFAULT_SYMBOL=BTC
DEFAULT_TIMEFRAME=4h
POLL_INTERVAL_SECONDS=60

# ─── Risk management ──────────────────────────────────────────────────────────
MAX_POSITION_SIZE_USD=1000.0
MAX_DAILY_LOSS_USD=500.0
# Sum of margin across all open positions — caps total exposure regardless
# of which strategy opened them. 0 disables the cap.
MAX_TOTAL_EXPOSURE_USD=5000.0
KILL_SWITCH=false

# ─── Telegram notifications (optional) ────────────────────────────────────────
# Create a bot at https://t.me/BotFather — copy the token it gives you.
# Get your chat ID by messaging https://t.me/userinfobot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_EVENTS=trade.executed,position.closed,error,vault.qualified,vault.disqualified

# ─── Dashboard / API ──────────────────────────────────────────────────────────
# API_KEY: if set, all POST/control requests must include X-Api-Key: <value>
# Leave empty to disable auth (fine for local dev).
API_KEY=
DASHBOARD_URL=http://localhost:3000
# Public URL where the dashboard is reachable from the user's browser.
# Used by OIDC to construct the redirect_uri sent to the provider.
# If unset, falls back to DASHBOARD_URL. In Docker without this set,
# OIDC will fail because req.url returns the internal container hostname.
PUBLIC_URL=http://localhost:3000
