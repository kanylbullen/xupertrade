# ─── Exchange mode ────────────────────────────────────────────────────────────
EXCHANGE_MODE=paper              # paper | testnet | mainnet

# ─── HyperLiquid — testnet ────────────────────────────────────────────────────
# Required when EXCHANGE_MODE=testnet
# Generate at: https://app.hyperliquid-testnet.xyz → Settings → API
HYPERLIQUID_PRIVATE_KEY=         # private key of the signing wallet (0x...)
HYPERLIQUID_ACCOUNT_ADDRESS=     # trading account address — leave empty if signing wallet IS the account

# ─── HyperLiquid — mainnet ────────────────────────────────────────────────────
# Required when EXCHANGE_MODE=mainnet (bot-mainnet container, --profile mainnet)
HYPERLIQUID_MAINNET_PRIVATE_KEY=
HYPERLIQUID_MAINNET_ACCOUNT_ADDRESS=

# ─── Vault tracking (read-only) ───────────────────────────────────────────────
# Mainnet wallet address used to query the user's vault deposits via HL's
# `userVaultEquities` endpoint. PUBLIC ADDRESS only — no private key — since
# vault equities are public on-chain. Leave empty to disable the
# "My vault positions" panel on the /vaults dashboard page.
VAULT_TRACKING_ADDRESS=

# ─── Paper trading ────────────────────────────────────────────────────────────
PAPER_INITIAL_BALANCE=10000.0

# ─── Database ─────────────────────────────────────────────────────────────────
# Required: docker-compose.yml uses `${POSTGRES_PASSWORD:?...}` interpolation
# for both the postgres service and the dashboard's DATABASE_URL — compose-up
# refuses to start if this is unset. In production, inject via Phase
# (`phase run -- docker compose ...`); for local dev, set in your .env.
#
# POSTGRES_PASSWORD must be URL-safe (no @ : / ? # =) — it is embedded in
# DATABASE_URL without URL-encoding. Recommended generator:
#   openssl rand -base64 36 | tr -d '/+='
#
# IMPORTANT: keep the password in DATABASE_URL below in sync with
# POSTGRES_PASSWORD above. They must match.
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/hypertrade

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Engine ───────────────────────────────────────────────────────────────────
DEFAULT_SYMBOL=BTC
DEFAULT_TIMEFRAME=4h
POLL_INTERVAL_SECONDS=60

# ─── Risk management ──────────────────────────────────────────────────────────
MAX_POSITION_SIZE_USD=1000.0
MAX_DAILY_LOSS_USD=500.0
# Sum of margin across all open positions — caps total exposure regardless
# of which strategy opened them. 0 disables the cap.
MAX_TOTAL_EXPOSURE_USD=5000.0
KILL_SWITCH=false

# ─── Mainnet allowlist (audit C3) ─────────────────────────────────────────────
# Comma-separated list of strategy names allowed to TRADE on mainnet. Empty
# = no strategies trade (mainnet bot still boots and serves /api/* but won't
# open new positions). Ignored on paper/testnet — both run the full set.
# Example: MAINNET_ENABLED_STRATEGIES=bb_short
# This is a HARD upper bound. Redis-side disable can subset further but
# cannot enable beyond this list.
MAINNET_ENABLED_STRATEGIES=

# ─── Telegram notifications (optional) ────────────────────────────────────────
# Create a bot at https://t.me/BotFather — copy the token it gives you.
# Get your chat ID by messaging https://t.me/userinfobot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_EVENTS=trade.executed,position.closed,error,vault.qualified,vault.disqualified,hodl.verdict_changed

# ─── Dashboard / API ──────────────────────────────────────────────────────────
# API_KEY: if set, all POST/control requests must include X-Api-Key: <value>
# Leave empty to disable auth (fine for local dev).
API_KEY=
DASHBOARD_URL=http://localhost:3000
# Public URL where the dashboard is reachable from the user's browser.
# Used by OIDC to construct the redirect_uri sent to the provider.
# If unset, falls back to DASHBOARD_URL. In Docker without this set,
# OIDC will fail because req.url returns the internal container hostname.
PUBLIC_URL=http://localhost:3000

# ─── OIDC invite gate (security audit M-3) ────────────────────────────────────
# When set, OIDC sign-in for a brand-new user only autocreates a tenant row
# if the IdP-issued `groups` claim contains this exact value. Empty/unset =
# no enforcement (back-compat: any successful OIDC auth autocreates a tenant).
# For Authentik-backed deployments the recommended value is `hypertrade-users`
# per docs/INVITE_ONBOARDING.md. Group enforcement only fires on autocreate;
# existing tenants are NOT re-checked on login (revocation flows through M-2's
# `is_active` flag, not group membership which can flap mid-session).
OIDC_REQUIRED_GROUP=
