# ─── Exchange mode ────────────────────────────────────────────────────────────
EXCHANGE_MODE=paper              # paper | testnet | mainnet

# ─── HyperLiquid — testnet ────────────────────────────────────────────────────
# Required when EXCHANGE_MODE=testnet
# Generate at: https://app.hyperliquid-testnet.xyz → Settings → API
HYPERLIQUID_PRIVATE_KEY=         # private key of the signing wallet (0x...)
HYPERLIQUID_ACCOUNT_ADDRESS=     # trading account address — leave empty if signing wallet IS the account

# ─── HyperLiquid — mainnet ────────────────────────────────────────────────────
# Required when EXCHANGE_MODE=mainnet (bot-mainnet container, --profile mainnet)
HYPERLIQUID_MAINNET_PRIVATE_KEY=
HYPERLIQUID_MAINNET_ACCOUNT_ADDRESS=

# ─── Paper trading ────────────────────────────────────────────────────────────
PAPER_INITIAL_BALANCE=10000.0

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker Compose default — matches postgres service in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hypertrade

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Engine ───────────────────────────────────────────────────────────────────
DEFAULT_SYMBOL=BTC
DEFAULT_TIMEFRAME=4h
POLL_INTERVAL_SECONDS=60

# ─── Risk management ──────────────────────────────────────────────────────────
MAX_POSITION_SIZE_USD=1000.0
MAX_DAILY_LOSS_USD=500.0
# Sum of margin across all open positions — caps total exposure regardless
# of which strategy opened them. 0 disables the cap.
MAX_TOTAL_EXPOSURE_USD=5000.0
KILL_SWITCH=false

# ─── Telegram notifications (optional) ────────────────────────────────────────
# Create a bot at https://t.me/BotFather — copy the token it gives you.
# Get your chat ID by messaging https://t.me/userinfobot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_EVENTS=trade.executed,position.closed,error,vault.qualified,vault.disqualified

# ─── Dashboard / API ──────────────────────────────────────────────────────────
# API_KEY: if set, all POST/control requests must include X-Api-Key: <value>
# Leave empty to disable auth (fine for local dev).
API_KEY=
DASHBOARD_URL=http://localhost:3000
# Public URL where the dashboard is reachable from the user's browser.
# Used by OIDC to construct the redirect_uri sent to the provider.
# If unset, falls back to DASHBOARD_URL. In Docker without this set,
# OIDC will fail because req.url returns the internal container hostname.
PUBLIC_URL=http://localhost:3000
